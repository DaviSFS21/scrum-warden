POSTGRES_DB=scrumwarden
POSTGRES_USER=scrumwarden
POSTGRES_PASSWORD=scrumwarden

DATABASE_URL=postgresql://scrumwarden:scrumwarden@localhost:5432/scrumwarden
JWT_SECRET=scrum-warden-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
APP_PORT=80

# ─────────────────────────────────────────────────────────────────────────────
# GitHub Secrets needed in Settings → Secrets → Actions:
#
#   VM_HOST          IP público da VM Oracle
#   VM_USER          Usuário SSH (ex: ubuntu)
#   VM_SSH_KEY       Conteúdo da chave privada SSH (.pem)
#   JWT_SECRET       JWT secret de produção
#   POSTGRES_PASSWORD Senha do Postgres em produção
#   DATABASE_URL     postgresql://scrumwarden:<password>@localhost:5432/scrumwarden
# ─────────────────────────────────────────────────────────────────────────────
