# Copy this file to .env and fill in your values before running docker compose.

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=scrumwarden
POSTGRES_USER=scrumwarden
POSTGRES_PASSWORD=scrumwarden

# ── Backend ──────────────────────────────────────────────────────────────────
# CHANGE THIS in production!
JWT_SECRET=scrum-warden-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# ── App ───────────────────────────────────────────────────────────────────────
# Host port that nginx will listen on (default: 80)
APP_PORT=80
