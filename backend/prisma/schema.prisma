generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SM
  PO
  MEMBER
}

model User {
  id                  String            @id @default(cuid())
  email               String            @unique
  name                String
  password            String
  role                Role              @default(MEMBER)
  active              Boolean           @default(true)
  createdAt           DateTime          @default(now())
  pointEntries        PointEntry[]
  expulsions          Expulsion[]
  evaluationsGiven    PacerEvaluation[] @relation("Evaluator")
  evaluationsReceived PacerEvaluation[] @relation("Evaluatee")
}

model Sprint {
  id               String            @id @default(cuid())
  name             String
  startDate        DateTime
  endDate          DateTime
  active           Boolean           @default(false)
  createdAt        DateTime          @default(now())
  pointEntries     PointEntry[]
  expulsions       Expulsion[]
  pacerEvaluations PacerEvaluation[]
}

model Rule {
  id           String       @id @default(cuid())
  name         String
  description  String
  points       Int
  active       Boolean      @default(true)
  pointEntries PointEntry[]
}

model PointEntry {
  id           String   @id @default(cuid())
  userId       String
  sprintId     String
  ruleId       String?
  points       Int
  note         String?
  isGoldenRule Boolean  @default(false)
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id])
  sprint       Sprint   @relation(fields: [sprintId], references: [id])
  rule         Rule?    @relation(fields: [ruleId], references: [id])
}

model Expulsion {
  id         String   @id @default(cuid())
  userId     String
  sprintId   String
  reason     String
  expelledAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])
  sprint     Sprint   @relation(fields: [sprintId], references: [id])
}

model PacerEvaluation {
  id            String   @id @default(cuid())
  sprintId      String
  evaluatorId   String
  evaluateeId   String
  proactivity   Int
  autonomy      Int
  collaboration Int
  delivery      Int
  createdAt     DateTime @default(now())

  sprint    Sprint @relation(fields: [sprintId], references: [id], onDelete: Cascade)
  evaluator User   @relation("Evaluator", fields: [evaluatorId], references: [id], onDelete: Cascade)
  evaluatee User   @relation("Evaluatee", fields: [evaluateeId], references: [id], onDelete: Cascade)

  @@unique([sprintId, evaluatorId, evaluateeId])
}
